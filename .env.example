# Copia in .env e compila. In produzione (PythonAnywhere) imposta valori reali.
SECRET_KEY=genera-una-chiave-lunga-e-casuale
DEBUG=False
# Su PythonAnywhere: il tuo dominio, es. tuonome.pythonanywhere.com
ALLOWED_HOSTS=tuonome.pythonanywhere.com
CSRF_TRUSTED_ORIGINS=https://tuonome.pythonanywhere.com
# In produzione, DOPO aver lanciato `collectstatic`, abilita i nomi hashati (cache-busting):
USE_MANIFEST_STATIC=True
