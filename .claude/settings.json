{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/format-py.sh",
            "statusMessage": "ruff + black sul file .py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/django-checks.sh",
            "timeout": 180,
            "statusMessage": "Django: migrazioni + test"
          }
        ]
      }
    ]
  }
}
